{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch EcoTrace Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/ecotrace-vscode"
      ],
      "outFiles": [
        "${workspaceFolder}/ecotrace-vscode/out/**/*.js"
      ],
      "preLaunchTask": "npm: compile"
    }
  ]
}
