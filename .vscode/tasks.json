{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: compile",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "npm run compile"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ecotrace-vscode"
      },
      "group": "build",
      "problemMatcher": [
        "$tsc"
      ],
      "detail": "tsc -p ./"
    }
  ]
}
